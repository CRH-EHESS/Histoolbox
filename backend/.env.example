# Copier ce fichier en .env et remplir les valeurs.
# Ne jamais commiter .env dans le dépôt.

# --- Authentification -------------------------------------------------------
# Clé partagée avec les bêta-testeurs. Doit être longue et aléatoire.
# Générer : openssl rand -hex 32
API_KEY=changeme

# --- CORS -------------------------------------------------------------------
# URL(s) du frontend autorisées (séparées par des virgules).
# GitHub Pages : https://<username>.github.io/<repo>
ALLOWED_ORIGINS=https://username.github.io/histoolbox

# --- Moteur d'inférence vLLM ------------------------------------------------
# URL accessible depuis CE serveur (via VPN si nécessaire).
VLLM_BASE_URL=http://<ip-vpn-vllm>:8000

# --- Nettoyage automatique --------------------------------------------------
CLEANUP_TTL_SECONDS=3600
CLEANUP_INTERVAL_SECONDS=600

# --- Logging ----------------------------------------------------------------
LOG_LEVEL=INFO
